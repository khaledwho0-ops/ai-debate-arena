# ===== AI DEBATE ARENA — Environment Variables =====
# Copy this file to .env and fill in your API keys

# PRIMARY: Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# FAST STREAMING: Groq (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# FALLBACK: GitHub Models (https://github.com/marketplace/models) — use your GitHub PAT
GITHUB_TOKEN=your_github_token_here

# FALLBACK: NVIDIA NIM (https://build.nvidia.com/)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Server
PORT=3000
